{
  "manifest_version": 3,
  "name": "Fresco New Tab",
  "description": "Your Fresco wallpaper on every new tab.",
  "version": "1.0.0",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "host_permissions": ["http://127.0.0.1:8765/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "newtab@fresco.app",
      "strict_min_version": "115.0"
    }
  }
}
